@page "/"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using PolicyEngine.Authorization.Constants
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Nav

@code {
    [CascadingParameter] 
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null) return;

        var authState = await AuthenticationStateTask;
        var canManagePolicies = (await AuthorizationService.AuthorizeAsync(authState.User, PolicyNames.ManagePolicies)).Succeeded;

        Nav.NavigateTo(canManagePolicies ? "/dashboard" : "/policies", replace: true);
    }
}