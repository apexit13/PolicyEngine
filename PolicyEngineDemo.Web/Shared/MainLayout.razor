@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using MudBlazor
@using PolicyEngineDemo.Shared.Constants

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
@*         <MudNavLink Href="/">
            <MudText Typo="Typo.h6" Class="ml-1"><b>Policy Engine Demo</b></MudText>
        </MudNavLink> *@
        <MudLink Href="/" Typo="Typo.h6" Class="ml-1" Color="Color.Inherit" Underline="Underline.None">
            <b>Policy Engine Demo</b>
        </MudLink>

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudChip T="string" Icon="@Icons.Material.Filled.Business"
                         Color="Color.Secondary" Size="Size.Small" Class="mr-2">
                    @GetTenantDisplay(context)
                </MudChip>
                <MudText Typo="Typo.body2" Class="mr-3 d-none d-sm-flex">
                    @context.User.Identity?.Name
                </MudText>
                <MudButton Color="Color.Inherit" Variant="Variant.Outlined"
                           Size="Size.Small" OnClick="BeginLogout">
                    Sign out
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" Variant="Variant.Outlined"
                           Size="Size.Small" Href="authentication/login">
                    Sign in
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Mini"
               OpenMiniOnHover="true" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    [Inject] NavigationManager Navigation { get; set; } = default!;

    private bool _drawerOpen = false;

    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1F4E79",
            Secondary = "#2E75B6",
            AppbarBackground = "#1F4E79",
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void BeginLogout()
    {
        Navigation.NavigateToLogout("authentication/logout");
    }

    private string GetTenantDisplay(AuthenticationState authState)
    {
        var tid = authState.User.FindFirst(ClaimNames.TenantId)?.Value
               ?? "Tenant";
        return tid.Length > 12 ? tid[..12] + "…" : tid;
    }
}
