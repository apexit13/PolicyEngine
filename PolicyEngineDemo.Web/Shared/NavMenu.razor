@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using PolicyEngineDemo.Shared.Interfaces
@using PolicyEngineDemo.Web.Services
@inject IRoleService RoleService

<MudNavMenu>
    <AuthorizeView Policy="Policy.Admin">
        <MudNavLink Href="/dashboard"
                    Icon="@Icons.Material.Filled.Dashboard">
            Dashboard
        </MudNavLink>
    </AuthorizeView>
    <MudNavLink Href="/policies" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Policy">
        Policies
    </MudNavLink>

    <AuthorizeView Policy="Policy.Admin">
        <MudNavLink Href="/policies/new"
                    Icon="@Icons.Material.Filled.AddCircle">
            New Policy
        </MudNavLink>
    </AuthorizeView>
</MudNavMenu>

@* @code {
    private bool _isAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await RoleService.IsAdminAsync();
    }
} *@
